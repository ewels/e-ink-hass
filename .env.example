# Only needed for local DEV tooling (npm run snapshot) — NOT used at runtime.
# In production the card reads data from Home Assistant's `hass` object directly.
#
# Copy to .env and fill in to dump real entity states into dev/hass-snapshot.json
# so the dev harness renders against your real data.
HA_BASE_URL=https://YOUR.ui.nabu.casa
HA_TOKEN=
